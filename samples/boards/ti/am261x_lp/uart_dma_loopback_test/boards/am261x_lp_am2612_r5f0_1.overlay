/*
 * Hardware Setup: Connect UART TX and RX pins with a jumper wire.
 * See pinctrl configuration below for pin assignments.
 */

#include <zephyr/dt-bindings/pinctrl/ti-am26x-pinctrl.h>

/ {
	aliases {
		uart-dut = &uart3;
	};
};

&edma0 {
	status = "okay";
};

&pinctrl {
	uart3_rx: uart3_rx_default {
		pinmux = <TI_AM26X_PINMUX(PIN_GPIO(119),
			(PIN_MODE(2) | PIN_PULL_DISABLE | PIN_SLEW_RATE_LOW))>;
	};

	uart3_tx: uart3_tx_default {
		pinmux = <TI_AM26X_PINMUX(PIN_GPIO(120),
			(PIN_MODE(2) | PIN_PULL_DISABLE | PIN_SLEW_RATE_LOW))>;
	};
};

&uart3 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart3_tx &uart3_rx>;
	pinctrl-names = "default";
};
